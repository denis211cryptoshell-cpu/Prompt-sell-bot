# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────────────────────────────────────

BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# SQLite (разработка — работает без настройки)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# PostgreSQL (продакшн — раскомментируйте и заполните)
# DATABASE_URL=postgresql+asyncpg://botuser:strongpassword@localhost:5432/botdb

# ─────────────────────────────────────────────────────────────────────────────
# Robokassa — платёжная система
# ЛК: https://auth.robokassa.ru/ → Магазины → ваш магазин → Технические настройки
# ─────────────────────────────────────────────────────────────────────────────

# Логин магазина (не email — идентификатор магазина в Robokassa)
ROBOKASSA_LOGIN=your_shop_login

# ── БОЕВЫЕ пароли (ROBOKASSA_TEST_MODE=False) ─────────────────────────────────
# ЛК → Технические настройки → Пароль #1 и Пароль #2
ROBOKASSA_PASSWORD1=your_production_password1
ROBOKASSA_PASSWORD2=your_production_password2

# ── ТЕСТОВЫЕ пароли (ROBOKASSA_TEST_MODE=True) ────────────────────────────────
# ЛК → Технические настройки → Тестовый пароль #1 и Тестовый пароль #2
# ⚠️ ВАЖНО: тестовые пароли — ОТДЕЛЬНЫЕ от боевых, генерируются в том же разделе ЛК
# При тест-режиме Robokassa проверяет подпись именно тестовыми паролями!
ROBOKASSA_TEST_PASSWORD1=your_test_password1
ROBOKASSA_TEST_PASSWORD2=your_test_password2

# Комиссия Robokassa (доля): 0.099 = 9.9%, 0.05 = 5%, 0.039 = 3.9%
# Уточните в ЛК → Тарифы
ROBOKASSA_COMMISSION_RATE=0.05

# True = тестовый режим (деньги НЕ списываются, нужны TEST_PASSWORD1/2)
# False = боевой режим (реальные платежи, нужны PASSWORD1/2)
ROBOKASSA_TEST_MODE=True

# ─────────────────────────────────────────────────────────────────────────────
# Режим проверки оплаты
# ─────────────────────────────────────────────────────────────────────────────

# poll    — бот сам проверяет Robokassa каждые N сек (рекомендуется для большинства хостингов)
# webhook — Robokassa шлёт уведомление на ваш сервер (нужен VPS с открытым портом)
# auto    — автоматически: webhook если WEBHOOK_HOST задан, иначе poll
PAYMENT_CHECK_MODE=poll

# Интервал проверки в секундах (только для poll)
PAYMENT_POLL_INTERVAL=30

# Через сколько минут считать заказ просроченным
PAYMENT_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# Webhook (только для VPS с открытым портом)
# ─────────────────────────────────────────────────────────────────────────────

# Публичный URL сервера (оставьте пустым если используете poll)
WEBHOOK_HOST=
WEBHOOK_PORT=8080
WEBHOOK_PATH=/payment/result

# ─────────────────────────────────────────────────────────────────────────────
# Приложение
# ─────────────────────────────────────────────────────────────────────────────

DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Продукт по умолчанию (только при первом запуске)
# ─────────────────────────────────────────────────────────────────────────────

DEFAULT_PRODUCT_NAME=Пак Премиум AI-Промптов
DEFAULT_PRODUCT_PRICE=299
