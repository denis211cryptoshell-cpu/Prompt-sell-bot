# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Your bot token from @BotFather (REQUIRED)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Comma-separated list of Telegram user IDs who have admin access
# Get your ID from @userinfobot
ADMIN_IDS=123456789

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# SQLite (development — default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# PostgreSQL (production on TimeWeb VPS)
# DATABASE_URL=postgresql+asyncpg://botuser:strongpassword@localhost:5432/botdb

# ─────────────────────────────────────────────────────────────────────────────
# Robokassa Payment Gateway
# ─────────────────────────────────────────────────────────────────────────────

# Get credentials at: https://merchant.robokassa.ru/
ROBOKASSA_LOGIN=your_shop_login
ROBOKASSA_PASSWORD1=your_password1_from_robokassa
ROBOKASSA_PASSWORD2=your_password2_from_robokassa

# Commission rate as decimal (default 5% = 0.05).
# Check your actual tariff in Robokassa personal account.
# Standard rates: 3.9% for legal entities, 5% for individuals
ROBOKASSA_COMMISSION_RATE=0.05

# Set to False when you're ready to take real money
ROBOKASSA_TEST_MODE=True

# ─────────────────────────────────────────────────────────────────────────────
# Webhook server (for Robokassa ResultURL notifications)
# ─────────────────────────────────────────────────────────────────────────────

# Your server's public URL (must be HTTPS for production, HTTP OK for testing)
# Robokassa will POST payment notifications to: WEBHOOK_HOST + WEBHOOK_PATH
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PORT=8080
WEBHOOK_PATH=/payment/result

# In Robokassa personal account → Shop settings, set:
#   ResultURL:  https://yourdomain.com/payment/result
#   SuccessURL: https://yourdomain.com/payment/success
#   FailURL:    https://yourdomain.com/payment/fail

# ─────────────────────────────────────────────────────────────────────────────
# Payment check mode
# ─────────────────────────────────────────────────────────────────────────────

# How the bot checks if a payment was completed:
#   "auto"    — use webhook if WEBHOOK_HOST is set, otherwise poll (DEFAULT)
#   "poll"    — bot polls Robokassa API every N seconds (for bothost.ru / no open port)
#   "webhook" — Robokassa sends POST to ResultURL (for VPS / TimeWeb with open port)
PAYMENT_CHECK_MODE=auto

# For bothost.ru: set poll mode explicitly
# PAYMENT_CHECK_MODE=poll

# How often to check payment status (seconds). Only used in poll mode.
PAYMENT_POLL_INTERVAL=30

# How many minutes before cancelling an unpaid order
PAYMENT_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────────────────────

# Set to true for verbose SQLAlchemy query logging
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Default Product (used only on first run if no product in DB)
# ─────────────────────────────────────────────────────────────────────────────

# This is the NET price (what you receive after Robokassa commission).
# The user will pay: price / (1 - ROBOKASSA_COMMISSION_RATE)
# Example: 299 RUB net → user pays 315 RUB (at 5% commission)
DEFAULT_PRODUCT_NAME=Пак Премиум AI-Промптов
DEFAULT_PRODUCT_PRICE=299
